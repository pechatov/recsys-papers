---
const target = `${import.meta.env.BASE_URL}summaries/papers.html`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>RecSys Papers</title>
    <meta name="last-modified" content="2026-07-04" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>Last updated: <time datetime="2026-07-04">2026-07-04</time></p>
    <p><a href={target}>Open the full paper catalog</a></p>
  </body>
</html>
